#!/bin/bash
source "$(dirname "$0")/_common.sh"
source /usr/share/yunohost/helpers

ynh_script_progression "Stopping service..."
ynh_systemctl --action=stop --service="$app.service"

ynh_script_progression "Updating application files..."
cp -r "$YNH_APP_BASEDIR/sources/." "$install_dir/"

ynh_script_progression "Updating Python dependencies..."
"$install_dir/venv/bin/pip" install --quiet --upgrade pip
"$install_dir/venv/bin/pip" install --quiet -r "$install_dir/requirements.txt"

ynh_script_progression "Ensuring adventures data dir..."
# Eventyr flyttede fra install-mappen til data_dir (per-eventyr-mapper). Ved
# upgrade fra en ældre version findes data_dir/adventures ikke endnu → opret +
# seed de medfølgende eventyr (kun hvis tom, så uploadede kort/redigeringer
# aldrig overskrives). Samme "if empty"-mønster som characters/ i install.
mkdir -p "$data_dir/adventures"
if [ -z "$(ls -A "$data_dir/adventures")" ]; then
    cp -r "$install_dir/adventures/." "$data_dir/adventures/" 2>/dev/null || true
fi
chown -R "$app:$app" "$data_dir/adventures"

ynh_script_progression "Regenerating database..."
DND_DB_PATH="$data_dir/srd35.db" "$install_dir/venv/bin/python" "$install_dir/importer.py"
chown "$app:$app" "$data_dir/srd35.db"

ynh_script_progression "Reconfiguring nginx..."
ynh_config_add_nginx

ynh_script_progression "Reconfiguring systemd..."
ynh_config_add_systemd

ynh_script_progression "Starting service..."
ynh_systemctl --action=start --service="$app.service"

ynh_script_progression "Upgrade complete!"
